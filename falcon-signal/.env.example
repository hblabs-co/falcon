MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=falcon

NATS_URL=nats://localhost:4222

# APNs — token-based auth (.p8 key from Apple Developer portal)
APNS_KEY_PATH=./certs/AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_BUNDLE_ID=co.hblabs.falcon.Falcon

# Set to "true" for App Store / TestFlight builds, "false" for simulator/dev
APNS_PRODUCTION=false

ADMIN_ALERT_WINDOW=2m
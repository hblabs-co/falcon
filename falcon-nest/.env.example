# Local-only dev portal config — copy to .env if you want to override.
# Defaults are sane; the .env file is optional.

# HTTP listen port. Pick something else if 8080 is taken locally
# (e.g. you're already running a dev falcon-api on the same host).
PORT=8080

# Debounce window for the file watcher. Editors emit 3-5 writes
# per ⌘S; this collapses them into one browser reload. Go duration
# syntax (100ms, 500ms, 2s).
DEBOUNCE_WINDOW=100ms

FALCON_ENV=env
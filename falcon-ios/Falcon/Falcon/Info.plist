<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>co.hblabs.falcon</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>falcon</string>
			</array>
		</dict>
	</array>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Falcon connects to your local development server for testing.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_http._tcp</string>
	</array>
	<key>NSFaceIDUsageDescription</key>
	<string>Falcon uses Face ID to securely protect your login session.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>

	<!-- Production metadata — required / strongly recommended before
	     App Store submission. -->

	<!-- Display name shown on the Home Screen + Settings. -->
	<key>CFBundleDisplayName</key>
	<string>Falcon</string>

	<!-- Copyright. Apple reads this for the Credits section in the
	     app's auto-generated "About" view and for legal notices. -->
	<key>NSHumanReadableCopyright</key>
	<string>© 2026 HB Labs SAS</string>

	<!-- App Store category — picks where Falcon lives in the browse
	     tree. "productivity" fits AI-driven workflow tools. -->
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.productivity</string>

	<!-- Export compliance — tells App Store Connect the app uses only
	     Apple-provided encryption (HTTPS / WebSocket TLS). Without this
	     every TestFlight build prompts a manual compliance form. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>

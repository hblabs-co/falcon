  "version": "0.2.0",
  "compounds": [
    {
      "name": "🚀 Falcon — All Services",
      "configurations": [
        "Debug API",
        "Debug Signal",
        "Debug Scout",
        "Debug Dispatch",
        "Debug Realtime",
        "Debug Match Engine",
        "Debug Storage",
        "Debug Normalizer"
      ],
      "stopAll": true,
      "preLaunchTask": "Docker: start infrastructure",
      "postDebugTask": "Docker: stop infrastructure",
    }
  ],
  "configurations": [
    {
      "name": "Debug API",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/falcon-api"
    },
    {
      "name": "Debug Signal",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/falcon-signal"
    },
    {
      "name": "Debug Scout",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/falcon-scout/scout"
    },
    {
      "name": "Debug Dispatch",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/falcon-dispatch"
    },
    {
      "name": "Debug Match Engine",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/falcon-match-engine"
    },
    {
      "name": "Debug Storage",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/falcon-storage"
    },
    {
      "name": "Debug Normalizer",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/falcon-normalizer"
    },
     {
      "name": "Debug Recruiter Rodeo Import",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/falcon-import/recruiter_rodeo"
    },
    {
      "name": "Debug Realtime",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/falcon-realtime"
    },
  ]
}

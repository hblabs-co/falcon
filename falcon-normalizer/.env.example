MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=falcon

NATS_URL=nats://localhost:4222

# LLM — works with any OpenAI-compatible endpoint.
# Local dev: Ollama (requires: ollama pull qwen2.5:7b)
LLM_URL=http://localhost:11434
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
LLM_PROVIDER=ollama

# Production: Mistral AI
# LLM_URL=https://api.mistral.ai
# LLM_API_KEY=<your-mistral-api-key>
# LLM_MODEL=mistral-small-latest
# LLM_PROVIDER=mistral

# Minimum LLM score (0–10) to publish a match.result event.
MATCH_ENGINE_SCORE_THRESHOLD=6.0

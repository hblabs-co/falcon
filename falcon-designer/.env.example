# Local-only dev server config — copy to .env and tweak.
# All values have sensible defaults so the file is optional.

# HTTP listen port. Pick any free port if 8083 is taken locally.
PORT=8083

# Extra directory watched for changes — typically a sibling repo
# folder where you drop screenshot assets. A change here also
# triggers the hot reload.
SCREENSHOTS_DIR=../assets/ios-screenshots

# How long to wait after a file write before broadcasting the
# reload. Editors often write 3-5 times during a single ⌘S; this
# collapses the burst into one reload. Use Go duration syntax
# (100ms, 500ms, 2s).
DEBOUNCE_WINDOW=100ms

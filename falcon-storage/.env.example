MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=falcon

NATS_URL=nats://localhost:4222

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cvs
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cvs
QDRANT_VECTOR_DIM=1024

# Ollama runs natively on macOS for Metal GPU acceleration.
# See root README for setup instructions.
# From inside Docker use http://host.docker.internal:11434 instead.
EMBEDDINGS_URL=http://localhost:11434/v1/embeddings
EMBEDDINGS_API_KEY=ollama
EMBEDDINGS_MODEL=bge-m3

# Change this in production — use a long random secret.
JWT_SECRET=change-me-in-production

PORT=8081

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=falcon

NATS_URL=nats://localhost:4222

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cvs

# Ollama runs natively on macOS for Metal GPU acceleration.
# See root README for setup instructions.
# From inside Docker use http://host.docker.internal:11434 instead.
EMBEDDINGS_URL=http://localhost:11434/v1/embeddings
EMBEDDINGS_API_KEY=ollama
EMBEDDINGS_MODEL=bge-m3

# Number of top candidates returned per project event.
DISPATCH_TOP_N=20

# Minimum cosine similarity score to consider a CV a match.
DISPATCH_SCORE_THRESHOLD=0.65
